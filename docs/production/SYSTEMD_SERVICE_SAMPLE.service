[Unit]
Description=Simple Case Portal
After=network.target

[Service]
WorkingDirectory=/var/www/casebridge
ExecStart=/usr/bin/dotnet /var/www/casebridge/SimpleCasePortal.Web.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=casebridge
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production
EnvironmentFile=/etc/casebridge/casebridge.env

[Install]
WantedBy=multi-user.target
