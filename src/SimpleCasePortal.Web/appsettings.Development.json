{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SimpleCasePortal;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "DevelopmentSeed": {
    "Enabled": true,
    "TemporaryPassword": "ChangeMe123!"
  },
  "Storage": {
    "Provider": "LocalDevelopment",
    "SignedUrlExpiryMinutes": 15,
    "MaxFileSizeMb": 200,
    "LocalRootPath": "src/SimpleCasePortal.Web/App_Data/LocalStorage",
    "LocalBaseUrl": "http://localhost:5187"
  },
  "ExternalApis": {
    "UseFakeClientsInDevelopment": true,
    "DentistApp": {
      "Endpoint": "/api/cases",
      "TimeoutSeconds": 60,
      "SendSignedFileUrls": false
    },
    "WorkflowApp": {
      "Endpoint": "/api/cases",
      "TimeoutSeconds": 60,
      "SendSignedFileUrls": false
    },
    "ProductionApp": {
      "Endpoint": "/api/cases",
      "TimeoutSeconds": 60,
      "SendSignedFileUrls": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
