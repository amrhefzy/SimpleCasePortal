@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="section-panel">
    <h1 class="h3 text-danger">Something went wrong</h1>
    <p class="text-muted">The request could not be completed. Please try again or contact an administrator if the problem continues.</p>

    @if (Model.StatusCode.HasValue)
    {
        <p class="mb-1"><strong>Status code:</strong> @Model.StatusCode</p>
    }

    @if (Model.ShowRequestId)
    {
        <p class="mb-0">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }
</section>
