@using SimpleCasePortal.Domain.Constants
@using System.Security.Claims
@inject SimpleCasePortal.Application.Interfaces.IPermissionService PermissionService
@inject SimpleCasePortal.Application.Interfaces.ICurrentUserService CurrentUserService
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var canViewAuditLogs = User.Identity?.IsAuthenticated == true &&
        !string.IsNullOrWhiteSpace(CurrentUserService.UserId) &&
        await PermissionService.HasPermissionAsync(CurrentUserService.UserId, PermissionNames.AuditView);
    var canViewReports = User.Identity?.IsAuthenticated == true &&
        !string.IsNullOrWhiteSpace(CurrentUserService.UserId) &&
        await PermissionService.HasPermissionAsync(CurrentUserService.UserId, PermissionNames.ReportsView);
    var canViewCases = User.Identity?.IsAuthenticated == true &&
        !string.IsNullOrWhiteSpace(CurrentUserService.UserId) &&
        (await PermissionService.HasPermissionAsync(CurrentUserService.UserId, PermissionNames.CasesViewAll) ||
            await PermissionService.HasPermissionAsync(CurrentUserService.UserId, PermissionNames.CasesViewOwn));
    var roleLabels = User.FindAll(ClaimTypes.Role).Select(claim => claim.Value).ToArray();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Simple Case Portal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SimpleCasePortal.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Simple Case Portal</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark @(currentController == "Home" ? "active fw-semibold" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (canViewCases)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "Cases" ? "active fw-semibold" : string.Empty)" asp-area="" asp-controller="Cases" asp-action="Index">Cases</a>
                                </li>
                            }
                            @if (canViewReports)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "Reports" ? "active fw-semibold" : string.Empty)" asp-area="" asp-controller="Reports" asp-action="Index">Reports</a>
                                </li>
                            }
                            @if (canViewAuditLogs)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark @(currentController == "Audit" ? "active fw-semibold" : string.Empty)" asp-area="" asp-controller="Audit" asp-action="Index">Audit Logs</a>
                                </li>
                            }
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item me-lg-3">
                                <span class="navbar-text text-dark d-block py-0">@User.Identity.Name</span>
                                @if (roleLabels.Length > 0)
                                {
                                    <span class="navbar-text text-muted small d-block py-0">@string.Join(", ", roleLabels)</span>
                                }
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-secondary btn-sm mt-1 mt-lg-0">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Simple Case Portal
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
