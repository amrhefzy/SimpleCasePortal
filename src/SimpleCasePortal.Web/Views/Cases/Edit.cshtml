@model SimpleCasePortal.Web.ViewModels.Cases.EditCaseViewModel

@{
    ViewData["Title"] = $"Edit {Model.CaseNumber}";
}

<div class="page-heading">
    <div>
        <p class="eyebrow mb-1">Case maintenance</p>
        <h1 class="h3 mb-1">Edit case</h1>
        <p class="text-muted mb-0">@Model.CaseNumber</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Back to details</a>
</div>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="section-panel">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger validation-summary mb-3"></div>

    <div class="mb-3">
        <label asp-for="CaseNumber" class="form-label"></label>
        <input asp-for="CaseNumber" class="form-control" readonly />
    </div>

    @if (Model.CanSelectDoctorClinic)
    {
        <div class="mb-3">
            <label asp-for="DoctorClinicId" class="form-label required-label"></label>
            <select asp-for="DoctorClinicId" asp-items="Model.DoctorClinicOptions" class="form-select">
                <option value="">Select doctor/clinic</option>
            </select>
            <span asp-validation-for="DoctorClinicId" class="text-danger"></span>
        </div>
    }

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="PatientName" class="form-label required-label"></label>
            <input asp-for="PatientName" class="form-control" />
            <span asp-validation-for="PatientName" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Age" class="form-label"></label>
            <input asp-for="Age" class="form-control" />
            <span asp-validation-for="Age" class="text-danger"></span>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="DateOfBirth" class="form-label"></label>
            <input asp-for="DateOfBirth" class="form-control" />
            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Gender" class="form-label"></label>
        <input asp-for="Gender" class="form-control" />
        <span asp-validation-for="Gender" class="text-danger"></span>
    </div>

    @if (Model.CanChangeStatus)
    {
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" asp-items="Html.GetEnumSelectList<SimpleCasePortal.Domain.Enums.CaseStatusEnum>()" class="form-select"></select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>
    }

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="5"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
