@model SimpleCasePortal.Web.ViewModels.Cases.CaseDetailsViewModel
@using SimpleCasePortal.Domain.Enums
@using SimpleCasePortal.Web.Ui

@{
    ViewData["Title"] = $"Case {Model.Case.CaseNumber}";
}

<div class="page-heading">
    <div>
        <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
            <h1 class="h3 mb-0">@Model.Case.CaseNumber</h1>
            <span class="badge @UiFormatters.CaseStatusBadgeClass(Model.Case.Status)">@Model.Case.Status</span>
        </div>
        <p class="text-muted mb-0">@Model.Case.PatientName</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-action="Index">Back to cases</a>
        @if (Model.CanEdit)
        {
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Case.Id">Edit case</a>
        }
    </div>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}
@if (TempData["SyncError"] is string syncError)
{
    <div class="alert alert-danger">@syncError</div>
}

<div class="row g-3">
    <div class="col-lg-4">
        <section class="section-panel h-100">
            <h2 class="h5">Case summary</h2>
            <dl class="detail-list mb-0">
                <dt>Status</dt>
                <dd><span class="badge @UiFormatters.CaseStatusBadgeClass(Model.Case.Status)">@Model.Case.Status</span></dd>
                <dt>Created</dt>
                <dd>@Model.Case.CreatedOn.ToLocalTime().ToString("g")</dd>
                <dt>Updated</dt>
                <dd>@(Model.Case.UpdatedOn?.ToLocalTime().ToString("g") ?? "-")</dd>
            </dl>
        </section>
    </div>
    <div class="col-lg-4">
        <section class="section-panel h-100">
            <h2 class="h5">Patient</h2>
            <dl class="detail-list mb-0">
                <dt>Name</dt>
                <dd>@Model.Case.PatientName</dd>
                <dt>Age</dt>
                <dd>@(Model.Case.Age?.ToString() ?? "-")</dd>
                <dt>Date of birth</dt>
                <dd>@(Model.Case.DateOfBirth?.ToString("yyyy-MM-dd") ?? "-")</dd>
                <dt>Gender</dt>
                <dd>@(Model.Case.Gender ?? "-")</dd>
            </dl>
        </section>
    </div>
    <div class="col-lg-4">
        <section class="section-panel h-100">
            <h2 class="h5">Doctor/Clinic</h2>
            <p class="mb-0">@Model.Case.DoctorClinicName</p>
        </section>
    </div>
</div>

<section class="section-panel mt-3">
    <h2 class="h5">Notes</h2>
    <p class="mb-0 text-break">@(string.IsNullOrWhiteSpace(Model.Case.Notes) ? "-" : Model.Case.Notes)</p>
</section>

<section class="section-panel mt-3">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h2 class="h5 mb-1">Files</h2>
            <p class="text-muted small mb-0">Allowed types: STL, JPG, PNG, PDF, ZIP. Downloads use secure signed redirects.</p>
        </div>
        <span class="badge text-bg-secondary">@Model.Files.Count file(s)</span>
    </div>
    @if (TempData["FileError"] is string fileError)
    {
        <div class="alert alert-danger">@fileError</div>
    }

    @if (Model.CanUploadFiles)
    {
        <form asp-controller="CaseFiles" asp-action="Upload" method="post" enctype="multipart/form-data" class="upload-panel row g-3 mb-3">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UploadFile.CaseId" name="CaseId" />
            <div class="col-md-3">
                <label asp-for="UploadFile.FileType" class="form-label"></label>
                <select asp-for="UploadFile.FileType" name="FileType" asp-items="Html.GetEnumSelectList<FileTypeEnum>()" class="form-select"></select>
            </div>
            <div class="col-md-6">
                <label asp-for="UploadFile.File" class="form-label"></label>
                <input asp-for="UploadFile.File" name="File" class="form-control" type="file" />
                <span asp-validation-for="UploadFile.File" class="text-danger"></span>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Upload file</button>
            </div>
        </form>
    }

    <div class="table-responsive">
        <table class="table table-sm table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>File</th>
                    <th>Size</th>
                    <th>Uploaded</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Files.Any())
                {
                    <tr>
                        <td colspan="5" class="empty-state py-4">No files uploaded yet.</td>
                    </tr>
                }
                else
                {
                    foreach (var file in Model.Files)
                    {
                        <tr>
                            <td><span class="badge text-bg-light border">@file.FileType</span></td>
                            <td class="text-break">@file.OriginalFileName</td>
                            <td>@UiFormatters.FileSize(file.FileSizeBytes)</td>
                            <td>@file.UploadedOn.ToLocalTime().ToString("g")</td>
                            <td class="text-end">
                                <div class="d-inline-flex flex-wrap justify-content-end gap-1">
                                    @if (Model.CanDownloadFiles)
                                    {
                                        <a class="btn btn-sm btn-outline-primary" asp-controller="CaseFiles" asp-action="Download" asp-route-id="@file.Id">Download</a>
                                    }
                                    @if (Model.CanDeleteFiles)
                                    {
                                        <form asp-controller="CaseFiles" asp-action="Delete" asp-route-id="@file.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="caseId" value="@Model.Case.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

<section class="section-panel mt-3">
    <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h2 class="h5 mb-1">Manual sync</h2>
            <p class="text-muted small mb-0">Send this case to external systems only when ready.</p>
        </div>
    </div>
    <div class="d-flex flex-wrap gap-2 mb-3">
        @if (Model.CanSyncDentist)
        {
            <form asp-controller="Sync" asp-action="SyncToDentist" asp-route-caseId="@Model.Case.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">Sync to Dentist App</button>
            </form>
        }
        @if (Model.CanSyncWorkflow)
        {
            <form asp-controller="Sync" asp-action="SyncToWorkflow" asp-route-caseId="@Model.Case.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">Sync to Workflow App</button>
            </form>
        }
        @if (Model.CanSyncProduction)
        {
            <form asp-controller="Sync" asp-action="SyncToProduction" asp-route-caseId="@Model.Case.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-primary">Sync to Production App</button>
            </form>
        }
        @if (!Model.CanSyncDentist && !Model.CanSyncWorkflow && !Model.CanSyncProduction)
        {
            <span class="text-muted">You do not have permission to sync this case.</span>
        }
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead>
                <tr>
                    <th>Target</th>
                    <th>Status</th>
                    <th>Last synced</th>
                    <th>External reference</th>
                    <th>Last error</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var status in Model.SyncStatuses.OrderBy(item => item.SyncTarget))
                {
                    <tr>
                        <td>@UiFormatters.SyncTargetLabel(status.SyncTarget)</td>
                        <td><span class="badge @UiFormatters.SyncStatusBadgeClass(status.SyncStatus)">@FormatSyncStatus(status.SyncStatus)</span></td>
                        <td>@(status.LastSyncedOn?.ToLocalTime().ToString("g") ?? "-")</td>
                        <td>@(status.ExternalReferenceId ?? "-")</td>
                        <td class="text-break">@(status.LastErrorMessage ?? "-")</td>
                        <td class="text-end">
                            @if (status.CanRetry && status.LatestSyncLogId.HasValue)
                            {
                                <form asp-controller="Sync" asp-action="Retry" asp-route-syncLogId="@status.LatestSyncLogId.Value" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="caseId" value="@Model.Case.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning">Retry</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

@if (Model.CanDelete)
{
    <form asp-action="Delete" asp-route-id="@Model.Case.Id" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-danger">Soft delete case</button>
    </form>
}

@functions {
    private static string FormatSyncStatus(SyncStatusEnum? status)
    {
        return status?.ToString() ?? "Not Synced";
    }
}
