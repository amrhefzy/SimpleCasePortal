@model SimpleCasePortal.Web.ViewModels.Cases.CaseListViewModel

@{
    ViewData["Title"] = "Cases";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Cases</h1>
    @if (Model.CanCreate)
    {
        <a class="btn btn-primary" asp-action="Create">Create case</a>
    }
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success">@statusMessage</div>
}

<form asp-action="Index" method="get" class="border rounded p-3 mb-3">
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="Filter.CaseNumber" class="form-label"></label>
            <input asp-for="Filter.CaseNumber" name="CaseNumber" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Filter.PatientName" class="form-label"></label>
            <input asp-for="Filter.PatientName" name="PatientName" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.Status" class="form-label"></label>
            <select asp-for="Filter.Status" name="Status" asp-items="Html.GetEnumSelectList<SimpleCasePortal.Domain.Enums.CaseStatusEnum>()" class="form-select">
                <option value="">All</option>
            </select>
        </div>
        @if (Model.CanFilterByDoctorClinic)
        {
            <div class="col-md-4">
                <label asp-for="Filter.DoctorClinicId" class="form-label"></label>
                <select asp-for="Filter.DoctorClinicId" name="DoctorClinicId" asp-items="Model.DoctorClinicOptions" class="form-select">
                    <option value="">All</option>
                </select>
            </div>
        }
        <div class="col-md-3">
            <label asp-for="Filter.CreatedFrom" class="form-label"></label>
            <input asp-for="Filter.CreatedFrom" name="CreatedFrom" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Filter.CreatedTo" class="form-label"></label>
            <input asp-for="Filter.CreatedTo" name="CreatedTo" class="form-control" />
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-outline-primary">Filter</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Clear</a>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Case number</th>
                <th>Patient</th>
                <th>Doctor/Clinic</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Cases.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No cases found.</td>
                </tr>
            }
            else
            {
                foreach (var caseItem in Model.Cases)
                {
                    <tr>
                        <td>@caseItem.CaseNumber</td>
                        <td>@caseItem.PatientName</td>
                        <td>@caseItem.DoctorClinicName</td>
                        <td>@caseItem.Status</td>
                        <td>@caseItem.CreatedOn.ToLocalTime().ToString("g")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@caseItem.Id">Details</a>
                            @if (Model.CanEdit)
                            {
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@caseItem.Id">Edit</a>
                            }
                            @if (Model.CanDelete)
                            {
                                <form asp-action="Delete" asp-route-id="@caseItem.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
