@model SimpleCasePortal.Web.ViewModels.Audit.AuditLogDetailsViewModel

@{
    ViewData["Title"] = $"Audit Log {Model.Log.Id}";
}

<div class="page-heading">
    <div>
        <p class="eyebrow mb-1">Audit event</p>
        <h1 class="h3 mb-1">Audit Log @Model.Log.Id</h1>
        <p class="text-muted mb-0">@Model.Log.Action</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back to audit logs</a>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <section class="section-panel h-100">
            <h2 class="h5">Event</h2>
            <dl class="detail-list mb-0">
                <dt>Created</dt>
                <dd>@Model.Log.CreatedOn.ToLocalTime().ToString("g")</dd>
                <dt>Action</dt>
                <dd><span class="badge text-bg-light border">@Model.Log.Action</span></dd>
                <dt>Entity</dt>
                <dd>@Model.Log.EntityName</dd>
                <dt>Entity ID</dt>
                <dd>@Model.Log.EntityId</dd>
            </dl>
        </section>
    </div>
    <div class="col-lg-6">
        <section class="section-panel h-100">
            <h2 class="h5">Request context</h2>
            <dl class="detail-list mb-0">
                <dt>User</dt>
                <dd>@Model.Log.UserDisplayName</dd>
                <dt>User ID</dt>
                <dd>@(Model.Log.UserId ?? "-")</dd>
                <dt>IP address</dt>
                <dd>@(Model.Log.IpAddress ?? "-")</dd>
                <dt>User agent</dt>
                <dd class="text-break">@(Model.Log.UserAgent ?? "-")</dd>
            </dl>
        </section>
    </div>
</div>

<section class="section-panel mt-3">
    <h2 class="h5">Old values</h2>
    @if (string.IsNullOrWhiteSpace(Model.Log.OldValues))
    {
        <p class="text-muted mb-0">No old values recorded.</p>
    }
    else
    {
        <pre class="audit-value-box mb-0"><code>@Model.Log.OldValues</code></pre>
    }
</section>

<section class="section-panel mt-3">
    <h2 class="h5">New values</h2>
    @if (string.IsNullOrWhiteSpace(Model.Log.NewValues))
    {
        <p class="text-muted mb-0">No new values recorded.</p>
    }
    else
    {
        <pre class="audit-value-box mb-0"><code>@Model.Log.NewValues</code></pre>
    }
</section>
